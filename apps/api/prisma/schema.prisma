generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  admin
  student
}

enum CourseStatus {
  draft
  published
  archived
}

enum LabStatus {
  active
  completed
  abandoned
}

model Tenant {
  id         String   @id @default(uuid())
  slug       String   @unique
  name       String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  users       User[]
  courses     Course[]
  brand_kit   BrandKit?
  enrollments Enrollment[]
}

model BrandKit {
  id          String   @id @default(uuid())
  tenant_id   String   @unique
  logo_url    String?
  colors_json Json?
  fonts_json  Json?
  domain      String?
  favicon_url String?
  created_at  DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
}

model User {
  id                  String    @id @default(uuid())
  tenant_id           String?
  email               String?
  phone               String?
  name                String
  role                Role      @default(student)
  username            String?
  language_pref       String    @default("en")
  class_grade         Int?
  division            String?
  is_active           Boolean   @default(true)
  email_verified      Boolean   @default(false)
  email_verify_token  String?
  reset_token         String?
  reset_token_expires DateTime?
  password_hash       String?
  last_login          DateTime?
  last_active         DateTime?
  created_at          DateTime  @default(now())

  tenant         Tenant?        @relation(fields: [tenant_id], references: [id])
  refresh_tokens RefreshToken[]
  enrollments    Enrollment[]
  submissions    Submission[]
  lab_sessions   LabSession[]
  certificates   Certificate[]
  activities     UserActivity[]
  badges         UserBadge[]
}

model Course {
  id             String       @id @default(uuid())
  tenant_id      String
  title_en       String
  title_hi       String?
  title_mr       String?
  description_en String?
  description_hi String?
  description_mr String?
  slug           String
  category       String?
  level          String?      @default("beginner")
  duration_hours Int?
  price          Int?         @default(0)
  tags_json      Json?
  thumbnail_url  String?
  target_grade   String?
  stream         String?      @default("GENERAL")
  playlist_url   String?
  status         CourseStatus @default(draft)
  created_by     String?
  created_at     DateTime     @default(now())

  tenant       Tenant        @relation(fields: [tenant_id], references: [id])
  lessons      Lesson[]
  enrollments  Enrollment[]
  certificates Certificate[]
}

model Lesson {
  id           String   @id @default(uuid())
  course_id    String
  title        String
  title_hi     String?
  title_mr     String?
  description  String?
  type         String   @default("video")
  order_index  Int      @default(0)
  content_url  String?
  duration_min Int?     @default(10)
  is_preview   Boolean  @default(false)
  created_at   DateTime @default(now())

  course       Course          @relation(fields: [course_id], references: [id], onDelete: Cascade)
  assessments  Assessment[]
  contents     LessonContent[]
  lab_sessions LabSession[]
}

model Enrollment {
  id           String    @id @default(uuid())
  user_id      String
  course_id    String
  tenant_id    String
  progress_pct Float     @default(0)
  enrolled_at  DateTime  @default(now())
  completed_at DateTime?

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@unique([user_id, course_id])
}

model Assessment {
  id         String   @id @default(uuid())
  lesson_id  String
  type       String   @default("quiz")
  max_score  Int      @default(100)
  pass_score Int      @default(60)
  created_at DateTime @default(now())

  lesson      Lesson       @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  questions   Question[]
  submissions Submission[]
}

model Question {
  id             String   @id @default(uuid())
  assessment_id  String
  type           String   @default("mcq")
  question_text  String
  options_json   Json?
  correct_answer String
  points         Int      @default(10)
  created_at     DateTime @default(now())

  assessment Assessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
}

model Submission {
  id            String   @id @default(uuid())
  user_id       String
  assessment_id String
  answers_json  Json
  score         Int      @default(0)
  passed        Boolean  @default(false)
  graded_at     DateTime @default(now())

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
}

model LessonContent {
  id           String   @id @default(uuid())
  lesson_id    String
  locale       String   @default("en")
  content_json Json
  status       String   @default("draft")
  approved_by  String?
  version      Int      @default(1)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  lesson   Lesson         @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  versions ContentVersion[]

  @@unique([lesson_id, locale])
}

model ContentVersion {
  id           String   @id @default(uuid())
  content_id   String
  locale       String
  version_no   Int
  content_json Json
  diff_json    Json?
  created_by   String?
  note         String?
  created_at   DateTime @default(now())

  content LessonContent @relation(fields: [content_id], references: [id], onDelete: Cascade)
}

model LabSession {
  id         String    @id @default(uuid())
  user_id    String
  lesson_id  String
  status     LabStatus @default(active)
  started_at DateTime  @default(now())
  ended_at   DateTime?

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
}

model Certificate {
  id        String   @id @default(uuid())
  user_id   String
  course_id String
  tenant_id String
  cert_code String   @unique
  score_pct Int      @default(100)
  issued_at DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@unique([user_id, course_id])
}

model Badge {
  id              String @id @default(uuid())
  code            String @unique
  name_en         String
  name_hi         String?
  name_mr         String?
  icon_emoji      String
  threshold_type  String
  threshold_value Int

  user_badges UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  user_id   String
  badge_id  String
  earned_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badge_id], references: [id])

  @@unique([user_id, badge_id])
}

model UserActivity {
  id            String   @id @default(uuid())
  user_id       String
  tenant_id     String
  activity_type String
  entity_id     String?
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
