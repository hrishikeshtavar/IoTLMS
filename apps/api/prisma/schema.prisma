generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String    @id @default(uuid())
  slug         String    @unique
  name         String
  brand_config Json?
  plan_id      String?
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())

  users        User[]
  courses      Course[]
  brand_kit    BrandKit?
}

model User {
  id            String    @id @default(uuid())
  tenant_id     String
  email         String?
  phone         String?
  name          String
  role          String    @default("student")
  language_pref String    @default("en")
  is_active     Boolean   @default(true)
  last_login    DateTime?
  created_at    DateTime  @default(now())

  tenant        Tenant    @relation(fields: [tenant_id], references: [id])
}

model BrandKit {
  id           String   @id @default(uuid())
  tenant_id    String   @unique
  logo_url     String?
  colors_json  Json?
  fonts_json   Json?
  domain       String?
  favicon_url  String?
  created_at   DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenant_id], references: [id])
}

model Course {
  id          String       @id @default(uuid())
  tenant_id   String
  title_en    String
  title_hi    String?
  title_mr    String?
  slug        String
  category    String?
  status      String       @default("draft")
  created_by  String?
  created_at  DateTime     @default(now())

  tenant      Tenant       @relation(fields: [tenant_id], references: [id])
  lessons     Lesson[]
  enrollments Enrollment[]
}

model Lesson {
  id          String       @id @default(uuid())
  course_id   String
  title       String
  type        String       @default("video")
  order_index Int          @default(0)
  content_url String?
  created_at  DateTime     @default(now())

  course      Course       @relation(fields: [course_id], references: [id])
  assessments Assessment[]
}

model Enrollment {
  id           String    @id @default(uuid())
  user_id      String
  course_id    String
  enrolled_at  DateTime  @default(now())
  progress_pct Float     @default(0)
  completed_at DateTime?

  course       Course    @relation(fields: [course_id], references: [id])
}

model Assessment {
  id          String       @id @default(uuid())
  lesson_id   String
  type        String       @default("quiz")
  max_score   Int          @default(100)
  pass_score  Int          @default(60)
  created_at  DateTime     @default(now())

  lesson      Lesson       @relation(fields: [lesson_id], references: [id])
  questions   Question[]
  submissions Submission[]
}

model Question {
  id             String     @id @default(uuid())
  assessment_id  String
  type           String     @default("mcq")
  question_text  String
  options_json   Json?
  correct_answer String
  points         Int        @default(10)
  created_at     DateTime   @default(now())

  assessment     Assessment @relation(fields: [assessment_id], references: [id])
}

model Submission {
  id            String     @id @default(uuid())
  user_id       String
  assessment_id String
  answers_json  Json
  score         Int        @default(0)
  passed        Boolean    @default(false)
  graded_at     DateTime   @default(now())

  assessment    Assessment @relation(fields: [assessment_id], references: [id])
}

model LessonContent {
  id          String         @id @default(uuid())
  lesson_id   String
  locale      String         @default("en")
  content_json Json
  status      String         @default("draft")
  approved_by String?
  version     Int            @default(1)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  lesson      Lesson         @relation(fields: [lesson_id], references: [id])
  versions    ContentVersion[]

  @@unique([lesson_id, locale])
}

model ContentVersion {
  id          String        @id @default(uuid())
  content_id  String
  locale      String
  version_no  Int
  content_json Json
diff_json   Json?
  created_by  String?
  note        String?
  created_at  DateTime      @default(now())

  content     LessonContent @relation(fields: [content_id], references: [id])
}
