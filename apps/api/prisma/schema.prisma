generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  brand_config Json?
  plan_id      String?
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())

  users     User[]
  courses   Course[]
  brand_kit BrandKit?
  payments  Payment[]
}

model User {
  id                 String    @id @default(uuid())
  tenant_id          String
  email              String?
  phone              String?
  name               String
  role               String    @default("student")
  language_pref      String    @default("en")
  is_active          Boolean   @default(true)
  last_login         DateTime?
  password_hash      String?
  refresh_token_hash String?
  last_active        DateTime?
  created_at         DateTime  @default(now())

  tenant         Tenant         @relation(fields: [tenant_id], references: [id])
  refresh_tokens RefreshToken[]
}

model BrandKit {
  id          String   @id @default(uuid())
  tenant_id   String   @unique
  logo_url    String?
  colors_json Json?
  fonts_json  Json?
  domain      String?
  favicon_url String?
  created_at  DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])
}

model Course {
  id         String   @id @default(uuid())
  tenant_id  String
  title_en   String
  title_hi   String?
  title_mr   String?
  slug       String
  category   String?
  status     String   @default("draft")
  created_by String?
  created_at DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenant_id], references: [id])
  lessons     Lesson[]
  enrollments Enrollment[]
}

model Lesson {
  id          String   @id @default(uuid())
  course_id   String
  title       String
  type        String   @default("video")
  order_index Int      @default(0)
  content_url String?
  created_at  DateTime @default(now())

  course      Course          @relation(fields: [course_id], references: [id])
  assessments Assessment[]
  contents    LessonContent[]
  labSessions LabSession[]
}

model Enrollment {
  id           String    @id @default(uuid())
  user_id      String
  course_id    String
  enrolled_at  DateTime  @default(now())
  progress_pct Float     @default(0)
  completed_at DateTime?

  course Course @relation(fields: [course_id], references: [id])
}

model Assessment {
  id         String   @id @default(uuid())
  lesson_id  String
  type       String   @default("quiz")
  max_score  Int      @default(100)
  pass_score Int      @default(60)
  created_at DateTime @default(now())

  lesson      Lesson       @relation(fields: [lesson_id], references: [id])
  questions   Question[]
  submissions Submission[]
}

model Question {
  id             String   @id @default(uuid())
  assessment_id  String
  type           String   @default("mcq")
  question_text  String
  options_json   Json?
  correct_answer String
  points         Int      @default(10)
  created_at     DateTime @default(now())

  assessment Assessment @relation(fields: [assessment_id], references: [id])
}

model Submission {
  id            String   @id @default(uuid())
  user_id       String
  assessment_id String
  answers_json  Json
  score         Int      @default(0)
  passed        Boolean  @default(false)
  graded_at     DateTime @default(now())

  assessment Assessment @relation(fields: [assessment_id], references: [id])
}

model LessonContent {
  id           String   @id @default(uuid())
  lesson_id    String
  locale       String   @default("en")
  content_json Json
  status       String   @default("draft")
  approved_by  String?
  version      Int      @default(1)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  lesson   Lesson           @relation(fields: [lesson_id], references: [id])
  versions ContentVersion[]

  @@unique([lesson_id, locale])
}

model ContentVersion {
  id           String   @id @default(uuid())
  content_id   String
  locale       String
  version_no   Int
  content_json Json
  diff_json    Json?
  created_by   String?
  note         String?
  created_at   DateTime @default(now())

  content LessonContent @relation(fields: [content_id], references: [id])
}

model LabSession {
  id         String    @id @default(uuid())
  user_id    String
  lesson_id  String
  status     String    @default("active")
  started_at DateTime  @default(now())
  ended_at   DateTime?

  lesson Lesson @relation(fields: [lesson_id], references: [id])
}

model Payment {
  id         String   @id @default(uuid())
  tenant_id  String
  student    String
  amount     Int
  method     String   @default("UPI")
  status     String   @default("paid")
  receipt_no String?
  created_at DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id])
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}

model Certificate {
  id         String   @id @default(uuid())
  user_id    String
  course_id  String
  tenant_id  String
  cert_code  String   @unique
  score_pct  Int      @default(100)
  issued_at  DateTime @default(now())

  @@unique([user_id, course_id])
}

model UserActivity {
  id            String   @id @default(uuid())
  user_id       String
  tenant_id     String
  activity_type String
  entity_id     String?
  created_at    DateTime @default(now())
}

model Badge {
  id              String      @id @default(uuid())
  code            String      @unique
  name_en         String
  name_hi         String?
  name_mr         String?
  icon_emoji      String
  threshold_type  String
  threshold_value Int

  user_badges UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  user_id   String
  badge_id  String
  earned_at DateTime @default(now())

  badge Badge @relation(fields: [badge_id], references: [id])

  @@unique([user_id, badge_id])
}
