# === DATABASE ===
DATABASE_URL=postgresql://iotlearn:password@localhost:5432/iotlearn_dev

# === JWT AUTH ===
JWT_SECRET=replace_with_64_char_random_string_never_commit_this
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string

# === RAZORPAY ===
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_webhook_secret

# === MINIO ===
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# === REDIS ===
REDIS_URL=redis://localhost:6379

# === EMAIL (Resend) ===
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@iotlearn.in

# === CORS ===
ALLOWED_ORIGINS=http://localhost:3000,https://*.iotlearn.in

# === RATE LIMIT (API) ===
THROTTLER_ENABLED=true
THROTTLER_TTL_MS=60000
THROTTLER_LIMIT=1000

# === MISC ===
NODE_ENV=development
SENTRY_DSN=
